prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: libavfilter
Description: FFmpeg audio/video filtering library
Version: 10.4.100
Requires: 
Requires.private: libswscale >= 8.3.100, libpostproc >= 58.3.100, libavformat >= 61.7.100, libavcodec >= 61.19.100, libswresample >= 5.3.100, libavutil >= 59.39.100
Conflicts:
Libs: -L${libdir}  -lavfilter 
Libs.private: -libpath:/usr/local/lib harfbuzz.lib -libpath:/usr/local/lib ass.lib gdi32.lib -libpath:/usr/local/lib harfbuzz.lib fribidi.lib freetype.lib -libpath:/usr/local/lib freetype.lib
Cflags: -I${includedir}
